# === Spotify Discovery Engine — credentials ===
# Copy this file to ".env" and fill in your values. NEVER commit .env (it's gitignored).

# Groq API key — ROTATE your old leaked key first at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_new_key_here

# How many random non-discovery reviews to also label (control sample for unbiased prevalence)
CONTROL_SAMPLE=500

# Reddit API (free): https://www.reddit.com/prefs/apps -> "create another app" -> type "script"
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=spotify-research by u/yourname
